pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                echo 'Skipping dependency installation for CI demo...'
                bat 'echo Dependencies stage executed'
            }
        }

        stage('Build') {
            steps {
                echo 'Checking Python Version...'
                bat '"D:\\Python\\python.exe" --version'
            }
        }

        stage('Test') {
            steps {
                echo 'Running Test Stage...'
                bat 'echo Test Successful'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Application...'
                bat 'echo Deployment Successful'
            }
        }
    }
}
