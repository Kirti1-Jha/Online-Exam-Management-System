pipeline {
    agent any

    stages {

        stage('Checkout Code') {
    steps {
        echo 'Cloning Repository...'
        git branch: 'main', url: 'https://github.com/Kirti1-Jha/Online-Exam-Management-System.git'
    }
}

        stage('Install Dependencies') {
    steps {
        echo 'Installing Python Dependencies...'
        bat '"D:\\Python\\python.exe" -m pip install --upgrade pip'
        bat '"D:\\Python\\python.exe" -m pip install -r requirements.txt'
    }
}

stage('Build') {
    steps {
        echo 'Checking Python Version...'
        bat '"D:\\Python\\python.exe" --version'
    }
}

        stage('Test') {
            steps {
                echo 'Running Basic Test...'
                bat 'echo Test Stage Executed Successfully'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Simulating Deployment...'
                bat 'echo Deployment Successful'
            }
        }
    }
}
